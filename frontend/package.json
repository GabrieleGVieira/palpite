{
  "name": "frontend",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "env -u NO_COLOR expo start",
    "android": "env -u NO_COLOR expo start --android",
    "ios": "env -u NO_COLOR expo start --ios",
    "web": "env -u NO_COLOR expo start --web",
    "export:android": "env -u NO_COLOR expo export --platform android",
    "export:web": "env -u NO_COLOR expo export --platform web",
    "build:web": "env -u NO_COLOR npx expo export --platform web && node ../scripts/prepare-expo-web-pwa.mjs dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint:commit": "commitlint",
    "prepare": "cd .. && husky frontend/.husky"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.10",
    "base64-arraybuffer": "^1.0.2",
    "eas-cli": "^19.1.0",
    "expo": "~54.0.33",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.23",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-router": "^6.0.24",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/react": "~19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "private": true
}
