{
  "expo": {
    "name": "Palpite!",
    "slug": "palpite",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-palpite.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f8ef"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Permita acesso as suas fotos para escolher uma imagem de perfil."
      }
    },
    "android": {
      "package": "com.palpite.app",
      "versionCode": 9,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1f7a4a"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/572a2d08-cd56-44f9-845a-40fdadf96b37"
    },
    "extra": {
      "eas": {
        "projectId": "2c312543-37bf-4de7-afb4-b43e1951079f"
      }
    },
    "owner": "gabriele.vieira"
  }
}
